<% title = book.title %>
<% bodyClass = 'show' %>

<h1><%= book.title %></h1>

<article>
  <p><strong>Autor:</strong> <%= book.author %></p>
  <p><%= book.description %></p>
</article>

<ul class="action-list">
  <li><a href="/books/<%= book.id %>/edit">Edytuj</a></li>
  <li><a href="/books">Wróć do listy</a></li>
</ul>
